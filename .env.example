# Vuqiro environment contract.
# Copy to .env (never commit real values). In development/test all services
# run with mock fallbacks when provider credentials are missing, so a fresh
# clone works without secrets. In production the API REFUSES TO BOOT if
# Supabase, the video provider, RevenueCat, Stripe or push are unconfigured
# (see packages/config assertProductionSafety) — mocks can never silently
# serve production traffic.

# --- App ---
# development | test | preview | staging | production
EXPO_PUBLIC_APP_ENV=development
APP_VERSION=0.1.0

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Same values, exposed to the Next.js admin app:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never expose to mobile/admin clients.
SUPABASE_SERVICE_ROLE_KEY=

# --- RevenueCat (Apple IAP / Google Play Billing) ---
REVENUECAT_IOS_API_KEY=
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
# Public SDK keys for the mobile app (same values as above; RC public keys are safe client-side):
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# --- Stripe Connect (creator payouts) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Video provider (mux | mock) ---
VIDEO_PROVIDER=mock
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_SECRET=
VIDEO_WEBHOOK_SECRET=

# --- Push notifications (expo | mock) ---
PUSH_PROVIDER=mock
# Optional Expo access token (enhanced-security orgs):
EXPO_ACCESS_TOKEN=

# Optional Mux signed playback (expiring stream URLs). Key pair from the Mux
# dashboard; the private key is the base64-encoded PEM Mux issues.
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# --- Transactional email (resend | mock) ---
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM="Vuqiro <no-reply@vuqiro.app>"

# --- Observability & support ---
SENTRY_DSN=
SUPPORT_EMAIL=support@vuqiro.app

# --- Public legal / support URLs ---
PUBLIC_TERMS_URL=
PUBLIC_PRIVACY_URL=
PUBLIC_SUPPORT_URL=
PUBLIC_COMMUNITY_GUIDELINES_URL=
PUBLIC_CREATOR_TERMS_URL=
PUBLIC_PAYOUT_TERMS_URL=

# --- API service ---
API_PORT=3002
API_BASE_URL=http://localhost:3002
# Comma-separated browser origins allowed by the API (required in production):
CORS_ORIGINS=http://localhost:3001
# Public admin console URL:
ADMIN_URL=http://localhost:3001
# Mobile -> API base URL (use your machine's LAN IP for physical devices):
EXPO_PUBLIC_API_URL=
# Admin -> API base URL:
NEXT_PUBLIC_API_URL=
# Admin dev-only mock mode (must be explicitly enabled; ignored in production):
NEXT_PUBLIC_ADMIN_ALLOW_MOCK=true
