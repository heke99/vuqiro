# Vuqiro environment contract.
# Copy to .env (never commit real values). All services run with mock fallbacks
# when provider credentials are missing, so a fresh clone works without secrets.

# --- App ---
EXPO_PUBLIC_APP_ENV=development

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Same values, exposed to the Next.js admin app:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never expose to mobile/admin clients.
SUPABASE_SERVICE_ROLE_KEY=

# --- RevenueCat (Apple IAP / Google Play Billing) ---
REVENUECAT_IOS_API_KEY=
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# --- Stripe Connect (creator payouts) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Video provider (mux | mock) ---
VIDEO_PROVIDER=mock
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_SECRET=
VIDEO_WEBHOOK_SECRET=

# --- Observability & support ---
SENTRY_DSN=
SUPPORT_EMAIL=support@vuqiro.app

# --- Public legal / support URLs ---
PUBLIC_TERMS_URL=
PUBLIC_PRIVACY_URL=
PUBLIC_SUPPORT_URL=
PUBLIC_COMMUNITY_GUIDELINES_URL=
PUBLIC_CREATOR_TERMS_URL=
PUBLIC_PAYOUT_TERMS_URL=

# --- API service ---
API_PORT=3002
API_BASE_URL=http://localhost:3002
