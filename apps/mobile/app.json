{
  "expo": {
    "name": "Vuqiro",
    "slug": "vuqiro",
    "scheme": "vuqiro",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.diversasolutions.vuqiro",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Vuqiro needs access to your photo library so you can select videos to upload.",
        "NSCameraUsageDescription": "Vuqiro uses the camera to record videos you choose to share.",
        "NSMicrophoneUsageDescription": "Vuqiro uses the microphone when recording videos with sound.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diversasolutions.vuqiro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070A"
      },
      "permissions": [
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "companyName": "Diversa Solutions LLC",
      "router": {},
      "eas": {
        "projectId": "437b3a9b-ce2c-4654-9ecb-9bebb9635b63"
      }
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#07070A"
        }
      ]
    ]
  }
}
