{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "seed:demo-creators": "tsx src/seed/runDemoSeed.ts",
    "seed:demo-creators:cleanup": "tsx src/seed/runDemoSeed.ts --cleanup",
    "test:video-access": "vitest run src/lib/videoAccess.test.ts src/routes/videoAccess.routes.test.ts src/seed/demoSeed.test.ts src/seed/demoSeed.io.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@supabase/supabase-js": "^2",
    "@vuqiro/config": "workspace:*",
    "@vuqiro/services": "workspace:*",
    "@vuqiro/types": "workspace:*",
    "hono": "^4.6.0",
    "zod": "^3.24.0",
    "@vuqiro/mock-data": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.3",
    "vitest": "^3.0.0"
  }
}
