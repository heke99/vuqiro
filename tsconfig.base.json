{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@vuqiro/types": ["./packages/types/src/index.ts"],
      "@vuqiro/mock-data": ["./packages/mock-data/src/index.ts"],
      "@vuqiro/ui": ["./packages/ui/src/index.ts"],
      "@vuqiro/config": ["./packages/config/src/index.ts"],
      "@vuqiro/services": ["./packages/services/src/index.ts"]
    }
  }
}
