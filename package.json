{
  "name": "vuqiro",
  "private": true,
  "version": "0.1.0",
  "description": "Vuqiro — global short-video creator platform by Diversa Solutions LLC.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm dev:mobile",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:admin": "pnpm --filter admin dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "fetch:references": "bash scripts/fetch-open-source-references.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "prettier": "latest",
    "typescript": "latest"
  }
}
