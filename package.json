{
  "name": "vuqiro",
  "private": true,
  "version": "0.1.0",
  "description": "Vuqiro — global short-video creator platform by Diversa Solutions LLC.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm dev:mobile",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:mobile:clear": "pnpm --filter mobile dev:clear",
    "dev:mobile:web": "pnpm --filter mobile dev:web",
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:video-access": "pnpm --filter api test:video-access",
    "seed:demo-creators": "pnpm --filter api seed:demo-creators",
    "seed:demo-creators:cleanup": "pnpm --filter api seed:demo-creators:cleanup",
    "format": "prettier --write .",
    "fetch:references": "bash scripts/fetch-open-source-references.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "vitest": "^3.0.0"
  }
}
